{
    "name": "paymenthub/laravel-payment-hub",
    "description": "Unified payment infrastructure for Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "payment",
        "payment-gateway",
        "stripe",
        "paypal",
        "worldline",
        "adyen",
        "saferpay",
        "datatrans",
        "payrexx"
    ],
    "authors": [
        {
            "name": "Dayanch Muhammetgeldiyev",
            "email": "66455000+dayanchm@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "PaymentHub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PaymentHub\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "PaymentHub\\PaymentHubServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

{
    "name": "paymenthub/laravel-payment-hub",
    "description": "Unified payment infrastructure for Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "payment",
        "payment-gateway",
        "stripe",
        "paypal"
    ],
    "authors": [
        {
            "name": "Dayanch Muhammetgeldiyev",
            "email": "66455000+dayanchm@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "PaymentHub\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PaymentHub\\PaymentHubServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}